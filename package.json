{
  "name": "focustube-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "author": "Kamrul Hasan",
  "description": "FocusTube (Backend) is the server-side repository for the FocusTube web app — a distraction-free learning platform built on top of YouTube. This backend handles video processing, AI-powered summaries, and RAG-based chatbot features that turn passive watching into active learning.",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --ignore-path .gitignore --write \"./src/**/*.+(js|ts|json)\"",
    "prettier:fix": "prettier --write \"./src/**/*.+(js|ts|json)\"",
    "prepare": "simple-git-hooks",
    "render-build": "npm ci --production=false && npm run build"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "bcrypt": "^6.0.0",
    "cls-rtracer": "^2.6.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-error-toolkit": "^1.2.1",
    "express-openapi-validator": "^5.6.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "http-status-toolkit": "^2.0.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.30",
    "mongoose": "^9.2.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "openai": "^6.27.0",
    "serve-favicon": "^2.5.1",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.8.1",
    "youtube-transcript": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.2.1",
    "@types/nodemon": "^1.19.6",
    "@types/serve-favicon": "^2.5.7",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "lint-staged": "^16.2.7",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.1.14",
    "simple-git-hooks": "^2.13.1",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npm exec lint-staged -- --concurrent false"
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  }
}
